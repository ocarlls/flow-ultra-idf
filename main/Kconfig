menu "AS6031 / Flow Meter"

    config AS6031_INTERNAL_TOTALIZER
        bool "Usar totalizador interno do AS6031"
        default y
        help
            Quando habilitado, o node tenta ler o volume acumulado no AS6031 via RAA
            e acorda 1x/dia por timer para transmitir.

    config AS6031_RAM_FLOW_VOLUME_INT_ADDR
        hex "RAA addr: RAM_R_FLOW_VOLUME_INT (DWORD)"
        default 0xFFFF
        depends on AS6031_INTERNAL_TOTALIZER
        help
            Endereco RAA (DWORD) da parte inteira do volume acumulado.
            O datasheet publico cita o nome mas nao fornece o endereco.
            Defina aqui quando descobrir o offset.

    config AS6031_RAM_FLOW_VOLUME_FRACTION_ADDR
        hex "RAA addr: RAM_R_FLOW_VOLUME_FRACTION (DWORD)"
        default 0xFFFF
        depends on AS6031_INTERNAL_TOTALIZER
        help
            Endereco RAA (DWORD) da parte fracionaria (fd32) do volume acumulado.

    config AS6031_VOLUME_INT_IS_MILLILITERS
        bool "Interpretar FLOW_VOLUME_INT como mL (u32)"
        default y
        depends on AS6031_INTERNAL_TOTALIZER
        help
            Alguns mapas de firmware reportam a parte inteira do totalizador como
            contador direto em mililitros. Quando habilitado, o firmware converte
            FLOW_VOLUME_INT para litros usando int/1000 e ignora a parte fracionaria.

    config AS6031_TOTALIZER_COUNTER_DECREASING
        bool "Contador interno decrescente"
        default y
        depends on AS6031_INTERNAL_TOTALIZER
        help
            Quando habilitado, o consumo diario e derivado como -(raw_atual - raw_anterior).
            Use quando o totalizador interno diminuir com o fluxo no mapa ativo.

    config AS6031_VALIDATE_MODE
        bool "Validacao: ler total e calcular L/min"
        default n
        depends on AS6031_INTERNAL_TOTALIZER
        help
            Quando habilitado (e com enderecos definidos), o node entra em um loop que
            le o totalizador periodicamente e imprime a taxa aproximada (L/min).

    config AS6031_VALIDATE_INTERVAL_MS
        int "Validacao: intervalo entre leituras (ms)"
        range 200 60000
        default 1000
        depends on AS6031_VALIDATE_MODE

    config AS6031_VALIDATE_NO_FLOW_THRESHOLD_MLPM
        int "Validacao: limiar de sem fluxo (mL/min)"
        range 1 100000
        default 100
        depends on AS6031_VALIDATE_MODE
        help
            Taxas absolutas abaixo desse limiar sao exibidas como 0 L/min
            para reduzir falsos positivos por jitter de leitura.

    config AS6031_VALIDATE_NEGATIVE_GLITCH_ML
        int "Validacao: tolerancia de glitch negativo (mL)"
        range 0 10000
        default 2
        depends on AS6031_VALIDATE_MODE
        help
            Pequenos deltas negativos (em modulo) sao tratados como 0 para
            compensar leituras inconsistentes entre parte inteira/fracionaria.

    config AS6031_MAINTENANCE_MODE
        bool "Manutencao: diagnostico continuo (sem sleep/sem TX)"
        default n
        depends on AS6031_INTERNAL_TOTALIZER
        help
            Mantem o node acordado e imprime informacoes de firmware, total e taxa.
            Nao entra em deep sleep e nao transmite.

    config AS6031_MAINTENANCE_INTERVAL_MS
        int "Manutencao: intervalo (ms)"
        range 200 60000
        default 1000
        depends on AS6031_MAINTENANCE_MODE

    config AS6031_MAX_DAILY_DELTA_LITERS
        int "Sanidade: delta maximo por dia (L)"
        range 1 1000000
        default 5000
        depends on AS6031_INTERNAL_TOTALIZER
        help
            Limite de sanidade para detectar endereco errado ou leitura corrompida.
            Se o total aumentar acima desse valor em um ciclo diario, marca anomalia.

    config AS6031_DAILY_WAKEUP_SECONDS
        int "Wakeup por timer no modo totalizador interno (segundos)"
        range 10 604800
        default 86400
        depends on AS6031_INTERNAL_TOTALIZER
        help
            Intervalo de wakeup por timer quando o node opera em Flow Meter Mode.
            Use valores baixos em bancada para validar contagem sem power-cycle.
            Em producao, use 86400 (1 dia).

    config AS6031_DISCOVERY_MODE
        bool "Discovery: varrer RAA para achar enderecos"
        default n
        depends on AS6031_INTERNAL_TOTALIZER
        help
            Quando os enderecos do totalizador estao indefinidos (0xFFFF), o firmware
            pode entrar automaticamente em um modo de varredura para sugerir candidatos.

    config AS6031_FORCE_SYS_INIT_ON_BOOT
        bool "Forcar RC_SYS_INIT no boot (modo totalizador interno)"
        default n
        depends on AS6031_INTERNAL_TOTALIZER
        help
            Envia RC_SYS_INIT (0x9A) ao iniciar para forcar a sequencia de boot do AS6031
            antes de habilitar MCT. Use para recuperacao em campo quando a leitura de
            firmware retorna 0xFFFFFFFF com frequencia.

    config AS6031_DISCOVERY_INTERVAL_MS
        int "Discovery: intervalo entre snapshots (ms)"
        range 100 60000
        default 5000
        depends on AS6031_DISCOVERY_MODE

    config AS6031_DISCOVERY_SAMPLES
        int "Discovery: numero de snapshots (N)"
        range 2 20
        default 2
        depends on AS6031_DISCOVERY_MODE
        help
            Numero de snapshots coletados antes de ranquear candidatos.
            N=2 reproduz o comportamento simples (antes/depois).

    config AS6031_DISCOVERY_TOPK
        int "Discovery: top K candidatos por faixa"
        range 1 100
        default 20
        depends on AS6031_DISCOVERY_MODE
        help
            Limita quantos candidatos (enderecos e pares 32.32) serao impressos.

    config AS6031_DISCOVERY_REPEAT_COUNT
        int "Discovery: repeticoes (0 = 1 rodada)"
        range 0 1000
        default 0
        depends on AS6031_DISCOVERY_MODE
        help
            Quantas rodadas de discovery executar quando os enderecos estiverem indefinidos.
            Em 0, executa 1 rodada (nao bloqueante) e segue para o fluxo normal.

    config AS6031_COMMISSIONING_TOF_MODE
        bool "Comissionamento: modo TOF continuo (Caminho B)"
        default n
        help
            Modo de bancada para validar leitura de TOF e vazao em tempo real,
            semelhante ao sketch Arduino. Nao entra em deep sleep e nao transmite.
            Para producao (deep sleep 1x/dia + ESP-NOW), mantenha desabilitado.

    config AS6031_COMMISSIONING_INTERVAL_MS
        int "Comissionamento: intervalo de amostragem (ms)"
        range 100 5000
        default 500
        depends on AS6031_COMMISSIONING_TOF_MODE

    config AS6031_COMMISSIONING_FLOW_THRESHOLD_MLPS
        int "Comissionamento: limiar minimo de fluxo (mL/s)"
        range 1 1000
        default 20
        depends on AS6031_COMMISSIONING_TOF_MODE
        help
            Fluxos absolutos abaixo desse limiar sao tratados como zero para reduzir ruido.

    config AS6031_DISCOVERY_INCLUDE_NVRAM
        bool "Discovery: incluir NVRAM (0x100..0x1FF)"
        default n
        depends on AS6031_DISCOVERY_MODE
        help
            Alguns firmwares podem persistir parte do totalizador em NVRAM.
            Habilite para varrer essa faixa alem da RAM.

endmenu

menu "Flow Mesh Network"

    config FLOW_MESH_MODE
        bool "Habilitar rede mesh (ESP-NOW + LoRa)"
        default n
        help
            Ativa o firmware dedicado de mesh em dois protocolos:
            - ESP-NOW (hidrômetros/METER -> SUBROOT)
            - LoRa (SUBROOT -> ... -> ROOT)

            Observacao: este modo e exclusivo e deve ser usado com
            LORA_TEST_MODE e ESPNOW_TEST_MODE desabilitados.

    choice FLOW_ROLE
        prompt "Papel na rede mesh"
        default FLOW_ROLE_ROOT
        depends on FLOW_MESH_MODE

        config FLOW_ROLE_METER
            bool "METER (ESP32-C6, somente ESP-NOW)"

        config FLOW_ROLE_SUBROOT
            bool "SUBROOT (ESP32-C6 + E220, ESP-NOW + LoRa)"

        config FLOW_ROLE_ROOT
            bool "ROOT (ESP32-C6 + E220, agrega e loga)"
    endchoice

    config FLOW_SUBROOT_SELF_TEST
        bool "SUBROOT: gerar sonda LoRa periodica"
        default n
        depends on FLOW_MESH_MODE && FLOW_ROLE_SUBROOT
        help
            Injeta um pacote sintetico METER_DATA diretamente no enlace LoRa para
            validar a camada SUBROOT -> ROOT sem depender de um METER via ESP-NOW.

    config FLOW_SUBROOT_SELF_TEST_INTERVAL_MS
        int "SUBROOT: intervalo da sonda LoRa (ms)"
        range 1000 60000
        default 5000
        depends on FLOW_SUBROOT_SELF_TEST

    config FLOW_SUBROOT_SELF_TEST_VOLUME_LITERS
        int "SUBROOT: volume fixo da sonda (L)"
        range 1 1000000
        default 4321
        depends on FLOW_SUBROOT_SELF_TEST

    config FLOW_SUBROOT_SELF_TEST_DELTA_LITERS
        int "SUBROOT: delta fixo da sonda (L)"
        range 1 1000000
        default 9
        depends on FLOW_SUBROOT_SELF_TEST

    # -----------------------------------------------------------------------
    # Teste de consumo de TRANSMISSAO (sem AS6031, dados sinteticos)
    # -----------------------------------------------------------------------
    config FLOW_METER_TX_TEST
        bool "METER: modo de teste so-transmissao (dados sinteticos, sem AS6031)"
        default n
        depends on FLOW_MESH_MODE && FLOW_ROLE_METER
        help
            Substitui o caminho normal do METER (que le o AS6031) por um caminho
            de TESTE que apenas gera pacotes sinteticos e os transmite por ESP-NOW.
            Serve para medir o consumo de energia SOMENTE da transmissao de dados.
            Nenhum SPI/sensor e inicializado.

    config FLOW_METER_LIGHT_SLEEP
        bool "METER teste: usar light sleep + WiFi duty-cycled (n = baseline deep sleep)"
        default y
        depends on FLOW_METER_TX_TEST
        help
            y: mantem WiFi vivo em light sleep com wake-window connectionless
               (wake-on-radio por WiFi: consegue RECEBER e fazer relay dormindo).
            n: baseline deep sleep so-transmissao (transmissor cego, menor consumo)
               para comparacao de corrente.

    config FLOW_SUBROOT_LIGHT_SLEEP
        bool "SUBROOT: light sleep + WiFi duty-cycled (RX connectionless)"
        default n
        depends on FLOW_MESH_MODE && FLOW_ROLE_SUBROOT
        help
            Faz o SUBROOT deixar de ser sempre-ligado e dormir em light sleep,
            acordando o WiFi periodicamente (mesma window/interval do METER) para
            receber os bursts ESP-NOW. O lado LoRa permanece (WOR vem na Fase 2).

    config FLOW_LS_WAKE_WINDOW_MS
        int "Light sleep: janela de escuta WiFi (ms)"
        range 5 2000
        default 30
        depends on FLOW_METER_TX_TEST || FLOW_SUBROOT_LIGHT_SLEEP
        help
            Tempo que o radio fica acordado escutando a cada intervalo. Deve ser
            menor que o intervalo. Janela maior = capta mais facil, gasta mais.

    config FLOW_LS_WAKE_INTERVAL_MS
        int "Light sleep: intervalo do duty-cycle WiFi (ms)"
        range 20 4000
        default 300
        depends on FLOW_METER_TX_TEST || FLOW_SUBROOT_LIGHT_SLEEP
        help
            Periodo do duty-cycle do radio. Intervalo maior = menor consumo medio,
            maior latencia de recepcao. METER e SUBROOT devem usar o mesmo par.

    config FLOW_LS_TX_BURST_MS
        int "Light sleep: duracao do burst de TX (ms)"
        range 10 8000
        default 350
        depends on FLOW_METER_TX_TEST
        help
            Repete o mesmo pacote por este tempo (>= 1 intervalo + janela) para
            cair em alguma janela de escuta do receptor, sem sincronia de relogio.

    config FLOW_LS_TX_SPACING_MS
        int "Light sleep: espacamento entre repeticoes do burst (ms)"
        range 1 1000
        default 25
        depends on FLOW_METER_TX_TEST
        help
            Intervalo entre copias dentro do burst. Deve ser <= janela de escuta.

    config FLOW_LS_TX_PERIOD_MS
        int "Light sleep: periodo entre relatorios originados (ms)"
        range 200 600000
        default 5000
        depends on FLOW_METER_TX_TEST

    config FLOW_LS_STATS_INTERVAL_S
        int "Light sleep: intervalo do resumo de estatisticas (s)"
        range 5 600
        default 30
        depends on FLOW_METER_TX_TEST || FLOW_SUBROOT_LIGHT_SLEEP

    config FLOW_LS_VERBOSE
        bool "Light sleep: logs verbosos (desligar para medir corrente limpa)"
        default y
        depends on FLOW_METER_TX_TEST || FLOW_SUBROOT_LIGHT_SLEEP

endmenu

menu "EBYTE E220 LoRa Radio"

    comment "Pinos = -1 ate o modulo ser fiado. O driver rejeita pinos invalidos."

    config FLOW_E220_UART_PORT
        int "UART usada pelo E220 (0 = console no ESP32-C6; use 1)"
        range 0 2
        default 1
        help
            Porta UART dedicada ao E220. No ESP32-C6 a UART0 e o console de log,
            entao use UART1.

    config FLOW_E220_PIN_TX
        int "GPIO TX do ESP (-> RXD do E220)"
        range -1 48
        default -1

    config FLOW_E220_PIN_RX
        int "GPIO RX do ESP (<- TXD do E220)"
        range -1 48
        default -1

    config FLOW_E220_PIN_M0
        int "GPIO M0 (saida; bit0 de modo)"
        range -1 48
        default -1

    config FLOW_E220_PIN_M1
        int "GPIO M1 (saida; bit1 de modo)"
        range -1 48
        default -1

    config FLOW_E220_PIN_AUX
        int "GPIO AUX (entrada; busy=0/ready=1)"
        range -1 48
        default -1

    config FLOW_E220_BAUD
        int "Baud da UART (deve casar com o gravado no modulo)"
        range 1200 115200
        default 9600

    config FLOW_E220_ADDRESS
        int "Endereco do modulo (ADDH:ADDL, 0-65535)"
        range 0 65535
        default 0
        help
            Mesmo endereco/canal/air-rate em todos os nos no modo transparente.

    config FLOW_E220_CHANNEL
        int "Canal RF (frequencia = 850.125 + CH MHz)"
        range 0 80
        default 65
        help
            E220-900T22: f = 850.125 MHz + canal x 1 MHz. CH=65 -> ~915 MHz.

    config FLOW_E220_AIR_DATA_RATE
        int "Air data rate (codigo REG0[2:0])"
        range 0 7
        default 2
        help
            Codigo de 3 bits do registrador. Menor taxa = maior alcance. O default
            (2) corresponde a ~2.4 kbps (maior alcance), equivalente a intencao de
            SF alto do driver SPI antigo.

    config FLOW_E220_TX_POWER_DBM
        int "Potencia TX (dBm; arredonda para 22/17/13/10)"
        range 10 22
        default 22

    config FLOW_E220_WOR_PERIOD_MS
        int "Periodo WOR (ms; 0 = WOR desabilitado)"
        range 0 4000
        default 0
        help
            Quando > 0, o modulo entra em wake-on-radio (escuta periodica).
            Passos de 500 ms no E220. 0 mantem o modulo em RX continuo/normal.

    config FLOW_E220_FIXED_MODE
        bool "Modo fixo (endereçado) em vez de transparente"
        default n
        help
            Mantenha desabilitado (transparente) salvo necessidade de endereçamento.

    config FLOW_E220_RSSI_BYTE
        bool "Anexar byte de RSSI ao pacote recebido"
        default y
        help
            Habilita o recurso de RSSI ambiente/por-pacote do E220. O SNR nao esta
            disponivel no modo transparente (renderizado como '--').

endmenu

menu "ESP-NOW Test Module"

    config ESPNOW_TEST_MODE
        bool "Habilitar modo teste dedicado ESP-NOW"
        default n
        help
            Quando habilitado, o firmware ignora o fluxo normal do hidrômetro
            e executa somente o módulo de teste ESP-NOW para validar comunicação
            entre placas.

    choice ESPNOW_TEST_ROLE
        prompt "Papel no teste ESP-NOW"
        default ESPNOW_TEST_ROLE_TX
        depends on ESPNOW_TEST_MODE

        config ESPNOW_TEST_ROLE_TX
            bool "TX (envia ping e espera ACK)"

        config ESPNOW_TEST_ROLE_RX
            bool "RX (recebe ping e responde ACK)"
    endchoice

    config ESPNOW_TEST_CHANNEL
        int "Canal Wi-Fi usado no ESP-NOW"
        range 1 13
        default 1
        depends on ESPNOW_TEST_MODE

    config ESPNOW_TEST_SEND_INTERVAL_MS
        int "Intervalo de envio no TX (ms)"
        range 100 60000
        default 1000
        depends on ESPNOW_TEST_MODE && ESPNOW_TEST_ROLE_TX

    config ESPNOW_TEST_PEER_MAC
        string "MAC do peer (formato AA:BB:CC:DD:EE:FF)"
        default "24:6F:28:00:00:01"
        depends on ESPNOW_TEST_MODE && ESPNOW_TEST_ROLE_TX
        help
            MAC da placa RX que respondera aos pings.

endmenu

menu "LoRa Test Module"

    config LORA_TEST_MODE
        bool "Habilitar modo teste dedicado LoRa"
        default n
        help
            Quando habilitado, o firmware ignora o fluxo normal do hidrômetro
            e executa somente o módulo de teste LoRa para validacao de alcance
            em topologia ROOT/NODE com o modulo EBYTE E220.

    choice LORA_TEST_ROLE
        prompt "Papel no teste LoRa"
        default LORA_TEST_ROLE_ROOT
        depends on LORA_TEST_MODE

        config LORA_TEST_ROLE_ROOT
            bool "ROOT (RX continuo, agrega estatisticas e responde ACK)"

        config LORA_TEST_ROLE_NODE
            bool "NODE (envia PROBE periodico e aguarda ACK)"
    endchoice

    config LORA_TEST_FREQUENCY_MHZ
        int "Frequencia LoRa (MHz)"
        range 137 1020
        default 915
        depends on LORA_TEST_MODE

    config LORA_TEST_NODE_SEND_INTERVAL_MS
        int "Intervalo base de envio do NODE (ms)"
        range 100 600000
        default 2000
        depends on LORA_TEST_MODE && LORA_TEST_ROLE_NODE

    config LORA_TEST_NODE_SEND_JITTER_MS
        int "Jitter aleatorio do NODE (ms)"
        range 0 60000
        default 250
        depends on LORA_TEST_MODE && LORA_TEST_ROLE_NODE
        help
            Offset aleatorio somado/subtraido do intervalo base para reduzir colisao.

    config LORA_TEST_ROOT_SUMMARY_INTERVAL_MS
        int "Intervalo do resumo do ROOT (ms)"
        range 1000 600000
        default 10000
        depends on LORA_TEST_MODE && LORA_TEST_ROLE_ROOT

endmenu
